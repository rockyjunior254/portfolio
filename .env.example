# Server-only contact notification configuration. Never prefix these with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_your_resend_key
CONTACT_FROM_EMAIL=Rocky Junior Portfolio <contact@your-verified-domain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Optional public CV URL. Set this when the CV is hosted on Google Drive, Dropbox, or another file host.
# NEXT_PUBLIC_CV_URL=https://example.com/rocky-junior-cv.pdf
